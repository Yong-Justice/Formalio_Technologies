{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "strict": true,
    "baseUrl": ".",
    "paths": {
      "@/*": [
        "src/*"
      ],
      "@app/*": [
        "app/*"
      ]
    },
    "types": [
      "nativewind/types"
    ]
  },
  "include": [
    "app",
    "src",
    "nativewind-env.d.ts",
    "app.config.ts"
  ]
}
